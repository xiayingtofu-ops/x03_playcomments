# Local platform URL.
PUBLIC_BASE_URL=http://127.0.0.1:8765

# Feishu OAuth callback path. Keep this in sync with Feishu Open Platform.
FEISHU_REDIRECT_PATH=/auth/feishu/callback

# Feishu self-built app credentials. Keep the real secret in .env only.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-with-your-app-secret
