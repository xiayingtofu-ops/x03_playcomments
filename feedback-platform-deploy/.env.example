# Local platform URL.
PUBLIC_BASE_URL=http://127.0.0.1:8765
ENTRY_PATH=/feedback.html
HOST=127.0.0.1
PORT=8765
DB_PATH=platform_feedback.db
UPLOAD_ROOT=platform_uploads
COOKIE_NAME=x03_session

# Feishu OAuth callback path. Keep this in sync with Feishu Open Platform.
FEISHU_REDIRECT_PATH=/auth/feishu/callback

# When credentials are configured, entering /feedback.html redirects to Feishu login first.
FEISHU_AUTH_REQUIRED=true

# Feishu self-built app credentials. Keep the real secret in .env only.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-with-your-app-secret

# Optional comma-separated admin identifiers: Feishu open_id, union_id, email, or display name.
PLATFORM_ADMIN_USERS=

# Feishu Base snapshot + writeback sync.
FEISHU_SYNC_ENABLED=true
FEISHU_SYNC_WRITEBACK_ENABLED=true
FEISHU_SYNC_INTERVAL_HOURS=24
FEISHU_CONNECTOR=C:\Users\Administrator\plugins\lark-enterprise\scripts\feishu-connector.cmd
FEISHU_BASE_TOKEN=PQTsbEtUPaV80isZ5dRcVFKsn6f
FEISHU_TABLE_ID=tblYhznxxvRtSyY9
FEISHU_VIEW_ID=vew9FrF9dW
FEISHU_BOT_WEBHOOK_URL=
